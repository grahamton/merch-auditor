{
  "name": "merch-auditor",
  "version": "0.5.1",
  "description": "Storefront auditing and comparison powered by the merch connector. Analyzes UX, conversion, copy, and competitive positioning.",
  "author": {
    "name": "grahamton"
  },
  "keywords": ["ecommerce", "storefront", "audit", "conversion", "merchandising"],
  "commands": [
    "./commands/audit.md",
    "./commands/compare.md",
    "./commands/research.md",
    "./commands/track.md"
  ],
  "mcpServers": {
    "merch-connector": {
      "command": "npx",
      "args": ["-y", "merch-connector@latest"],
      "env": {}
    }
  },
  "compatibility": {
    "mcpVersion": ">=2.0.0"
  }
}
